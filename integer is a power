#include <iostream>
bool isPowerOfTwo(int n) {
    return n > 0 && (n & (n - 1)) == 0;
}
int main() {
    int num;
    std::cout << "Enter an integer: ";
    std::cin >> num;
    if (isPowerOfTwo(num)) {
        std::cout << num << " is a power of 2." << std::endl;
    } else {
        std::cout << num << " is NOT a power of 2." << std::endl;
    }
    return 0;
}
